<Window x:Class="FocusTrackingTimer.App.ProjectMemoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="작업 메모"
        Icon="/Assets/app-icon.ico"
        Width="420"
        Height="390"
        MinWidth="360"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource ThemeBaseBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="{Binding ProjectName}" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="{StaticResource ThemeSecondaryTextBrush}"
                       Text="{Binding CreatedAtText}" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{StaticResource ThemeSecondaryTextBrush}"
                       Text="{Binding MemoUpdatedAtText}" />
        </StackPanel>

        <TextBox Grid.Row="1"
                 Margin="0,16,0,16"
                 Padding="10"
                 AcceptsReturn="True"
                 BorderBrush="{StaticResource ThemeSecondaryBorderBrush}"
                 BorderThickness="1"
                 Text="{Binding MemoText, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="78"
                    Height="34"
                    Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="CancelButton_Click"
                    Content="취소" />
            <Button Width="78"
                    Height="34"
                    Style="{StaticResource PrimaryButton}"
                    Click="SaveButton_Click"
                    Content="저장"
                    Foreground="{StaticResource ThemeActiveTextBrush}" />
        </StackPanel>
    </Grid>
</Window>
