<UserControl x:Class="FocusTrackingTimer.App.Views.DailyRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Panel}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="508" />
                <ColumnDefinition Width="2" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="12,0"
                                HorizontalAlignment="Stretch">
                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="작업 일수" />
                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" FontSize="22" FontWeight="SemiBold" Text="{Binding MonthlyWorkedDayCountText}" />
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource Divider}" />
                    <StackPanel Grid.Column="2"
                                Margin="12,0"
                                HorizontalAlignment="Stretch">
                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="월간 작업 시간" />
                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" FontSize="22" FontWeight="SemiBold" Text="{Binding MonthlyTotalWallClockDurationText}" />
                    </StackPanel>

                    <Border Grid.Column="3" Style="{StaticResource Divider}" />
                    <StackPanel Grid.Column="4"
                                Margin="12,0"
                                HorizontalAlignment="Stretch">
                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="월간 집중 시간" />
                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource ThemeFocusBrush}" Text="{Binding MonthlyTotalFocusDurationText}" />
                    </StackPanel>

                    <Border Grid.Column="5" Style="{StaticResource Divider}" />
                    <StackPanel Grid.Column="6"
                                Margin="12,0"
                                HorizontalAlignment="Stretch">
                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="평균 집중 시간" />
                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource ThemeFocusBrush}" Text="{Binding MonthlyAverageFocusDurationText}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Style="{StaticResource SectionHorizontalDivider}" />

                <Grid Grid.Row="2"
                      Width="448"
                      Margin="0,16,0,0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel HorizontalAlignment="Center"
                                Orientation="Horizontal">
                        <Button Width="32" Height="32" Margin="0,0,8,0" Style="{StaticResource IconButton}" Click="PreviousRecordYearButton_Click">
                            <Image Width="24" Height="24" Source="/Assets/chevrons-left.png" Stretch="Uniform" />
                        </Button>
                        <Button Width="32" Height="32" Style="{StaticResource IconButton}" Click="PreviousRecordMonthButton_Click">
                            <Image Width="24" Height="24" Source="/Assets/chevron-left.png" Stretch="Uniform" />
                        </Button>
                        <TextBlock Margin="14,0" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="{Binding DisplayedRecordMonthText}" />
                        <Button Width="32" Height="32" Style="{StaticResource IconButton}" Click="NextRecordMonthButton_Click">
                            <Image Width="24" Height="24" Source="/Assets/chevron-right.png" Stretch="Uniform" />
                        </Button>
                        <Button Width="32" Height="32" Margin="8,0,0,0" Style="{StaticResource IconButton}" Click="NextRecordYearButton_Click">
                            <Image Width="24" Height="24" Source="/Assets/chevrons-right.png" Stretch="Uniform" />
                        </Button>
                        <Button Width="32" Height="32" Margin="8,0,0,0" Style="{StaticResource IconButton}" Click="CurrentRecordMonthButton_Click">
                            <Image Width="24" Height="24" Source="/Assets/current-month.png" Stretch="Uniform" />
                        </Button>
                    </StackPanel>

                    <UniformGrid Grid.Row="1"
                                 Margin="0,18,0,8"
                                 Columns="7">
                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource ThemeSundayBrush}" Text="일" />
                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="월" />
                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="화" />
                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="수" />
                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="목" />
                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="금" />
                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="토" />
                    </UniformGrid>

                    <ItemsControl Grid.Row="2"
                                  Height="396"
                                  ItemsSource="{Binding CalendarRows}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Padding="0"
                                        Background="{StaticResource ThemeTransparentBrush}"
                                        BorderThickness="0"
                                        FocusVisualStyle="{x:Null}"
                                        Focusable="False"
                                        Click="CalendarDayButton_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="IsEnabled" Value="True" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="CellChrome"
                                                                Height="62"
                                                                Margin="2"
                                                                Padding="6"
                                                                Background="{StaticResource ThemeTransparentBrush}"
                                                                CornerRadius="8">
                                                            <Grid>
                                                                <StackPanel HorizontalAlignment="Left"
                                                                            VerticalAlignment="Top"
                                                                            Orientation="Horizontal">
                                                                    <TextBlock FontWeight="SemiBold"
                                                                               Text="{Binding DayText}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="{StaticResource ThemePrimaryTextBrush}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsSunday}" Value="True">
                                                                                        <Setter Property="Foreground" Value="{StaticResource ThemeSundayBrush}" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <Border Margin="4,0,0,0">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource ThemeTagTextBrush}"
                                                                                   Text="오늘" />
                                                                    </Border>
                                                                </StackPanel>

                                                                <Border Width="{Binding DotSize}"
                                                                        Margin="0,0,0,4"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Bottom"
                                                                        Background="{StaticResource ThemeFocusBrush}"
                                                                        CornerRadius="3">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Height" Value="3" />
                                                                            <Setter Property="Opacity" Value="0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding DotSize}" Value="12">
                                                                                    <Setter Property="Height" Value="3" />
                                                                                    <Setter Property="Opacity" Value="0.35" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding DotSize}" Value="15">
                                                                                    <Setter Property="Height" Value="4" />
                                                                                    <Setter Property="Opacity" Value="0.5" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding DotSize}" Value="18">
                                                                                    <Setter Property="Height" Value="5" />
                                                                                    <Setter Property="Opacity" Value="0.65" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding DotSize}" Value="21">
                                                                                    <Setter Property="Height" Value="6" />
                                                                                    <Setter Property="Opacity" Value="0.8" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding DotSize}" Value="24">
                                                                                    <Setter Property="Height" Value="7" />
                                                                                    <Setter Property="Opacity" Value="1" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>
                                                            </Grid>
                                                        </Border>

                                                        <ControlTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                                                <Setter TargetName="CellChrome" Property="Opacity" Value="0" />
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasDuration}" Value="False">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="CellChrome" Property="Background" Value="{StaticResource ThemeSelectionBrush}" />
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                <Setter TargetName="CellChrome" Property="Background" Value="{StaticResource ThemeLightSurfaceBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter TargetName="CellChrome" Property="Background" Value="{StaticResource ThemeLightSurfaceBrush}" />
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>

            <Border Grid.Column="1"
                    Style="{StaticResource SectionVerticalDivider}" />

            <Grid Grid.Column="2"
                  Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="{Binding SelectedDailyDateText}" />

                <UniformGrid Grid.Row="1"
                             HorizontalAlignment="Stretch"
                             Margin="0,14,0,18"
                             Columns="3"
                             Rows="1">
                    <Border Margin="0,0,8,0" Padding="12" Background="{StaticResource ThemeLightSurfaceBrush}" CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="작업 건수" />
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" Text="{Binding SelectedDailyRecordCountText}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,0" Padding="12" Background="{StaticResource ThemeLightSurfaceBrush}" CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="총 작업 시간" />
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" Text="{Binding SelectedDailyTotalWallClockDurationText}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0" Padding="12" Background="{StaticResource ThemeLightSurfaceBrush}" CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="집중 시간" />
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ThemeFocusBrush}" Text="{Binding SelectedDailyFocusSummaryText}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="작업 기록" />

                    <Grid Grid.Row="1"
                          Margin="0,8,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SelectedDailyRecordRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,12"
                                                BorderBrush="{StaticResource ThemeHoverBorderBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Ellipse Width="8" Height="8" Margin="0,6,10,0" Fill="{StaticResource ThemeStatusBrush}" VerticalAlignment="Top" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding ProjectName}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Margin="0,5,0,0" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="{Binding PeriodText}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Margin="4,0,14,0" FontWeight="SemiBold" Foreground="{StaticResource ThemeFocusBrush}" Text="{Binding DurationText}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock VerticalAlignment="Bottom"
                                   Foreground="{StaticResource ThemeHintTextBrush}"
                                   Text="{Binding SelectedDailyEmptyText}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
