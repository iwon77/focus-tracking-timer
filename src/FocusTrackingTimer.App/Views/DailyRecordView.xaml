<UserControl x:Class="FocusTrackingTimer.App.Views.DailyRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource Panel}" Padding="16">
            <StackPanel>
                <Button Height="52"
                        Margin="0,0,0,12"
                        Background="{Binding CalendarButtonBackground}"
                        BorderBrush="#2F2F2F"
                        BorderThickness="2"
                        Click="CalendarRecordButton_Click"
                        Visibility="Collapsed"
                        Content="캘린더" />
                <Button Height="52"
                        Margin="0,0,0,12"
                        Background="{Binding RecentButtonBackground}"
                        BorderBrush="#2F2F2F"
                        BorderThickness="2"
                        Click="RecentRecordButton_Click"
                        Visibility="Collapsed"
                        Content="최근 기록" />
                <TextBlock Margin="0,18,0,8" FontWeight="SemiBold" Text="프로젝트 필터" />
                <ComboBox Padding="8"
                          BorderBrush="#2F2F2F"
                          BorderThickness="2"
                          DisplayMemberPath="Label"
                          ItemsSource="{Binding RecordFilterOptions}"
                          SelectedItem="{Binding SelectedRecordFilter, Mode=TwoWay}"
                          SelectionChanged="RecordFilter_SelectionChanged" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource Panel}" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding RecordHeadlineText}" />
                        <TextBlock Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Foreground="#2E6D36" Text="{Binding TodayWorkedText}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="{Binding SelectedRecordFilterLabel}" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Panel}" Padding="20" Visibility="{Binding CalendarRecordVisibility}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="캘린더형 요약" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Width="54"
                                    Height="32"
                                    Margin="0,0,8,0"
                                    Background="#FFFFFF"
                                    BorderBrush="#D7D7D0"
                                    BorderThickness="1.5"
                                    Click="PreviousRecordYearButton_Click"
                                    Content="-1Y" />
                            <Button Width="32"
                                    Height="32"
                                    Background="#FFFFFF"
                                    BorderBrush="#D7D7D0"
                                    BorderThickness="1.5"
                                    Click="PreviousRecordMonthButton_Click"
                                    Content="‹" />
                            <Button Width="58"
                                    Height="32"
                                    Margin="8,0,0,0"
                                    Background="#FFFFFF"
                                    BorderBrush="#D7D7D0"
                                    BorderThickness="1.5"
                                    Click="CurrentRecordMonthButton_Click"
                                    Content="이번 달" />
                            <TextBlock Margin="12,0"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding DisplayedRecordMonthText}" />
                            <Button Width="32"
                                    Height="32"
                                    Background="#FFFFFF"
                                    BorderBrush="#D7D7D0"
                                    BorderThickness="1.5"
                                    Click="NextRecordMonthButton_Click"
                                    Content="›" />
                            <Button Width="54"
                                    Height="32"
                                    Margin="8,0,0,0"
                                    Background="#FFFFFF"
                                    BorderBrush="#D7D7D0"
                                    BorderThickness="1.5"
                                    Click="NextRecordYearButton_Click"
                                    Content="+1Y" />
                        </StackPanel>
                    </Grid>
                    <ItemsControl Grid.Row="1" Margin="0,18,0,0" ItemsSource="{Binding CalendarRows}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4"
                                        Padding="8"
                                        Background="#FFFFFF"
                                        BorderBrush="#D5D5D5"
                                        BorderThickness="1.5"
                                        CornerRadius="8"
                                        MouseEnter="CalendarDayBorder_MouseEnter"
                                        MouseLeave="CalendarDayBorder_MouseLeave">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding DayText}" />
                                        <Ellipse Width="18" Height="18" Margin="0,10,0,8">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Setter Property="Fill" Value="#26C567" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDuration}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock HorizontalAlignment="Center" Foreground="#2E6D36" FontSize="11" Text="{Binding DurationText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Grid.RowSpan="2"
                            Width="240"
                            Margin="0,52,0,0"
                            Padding="16"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="#1F1F1F"
                            BorderBrush="#1F1F1F"
                            BorderThickness="1.5"
                            CornerRadius="12"
                            Panel.ZIndex="5"
                            Visibility="{Binding CalendarHoverCardVisibility}">
                        <StackPanel>
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF"
                                       Text="{Binding CalendarHoverTitle}" />
                            <ScrollViewer Height="132"
                                          Margin="0,10,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CalendarHoverLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,0,0,8"
                                                       Foreground="#E5E7EB"
                                                       Text="{Binding}"
                                                       TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Panel}" Padding="20" Visibility="{Binding RecentRecordVisibility}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="최근 기록 리스트" />
                    <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecentRecordRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12" Padding="16" Background="#F3F3F3" BorderBrush="#2F2F2F" BorderThickness="1.5" CornerRadius="8">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left" FontSize="18" FontWeight="SemiBold" Text="{Binding ProjectName}" />
                                                <TextBlock HorizontalAlignment="Right" FontSize="18" FontWeight="SemiBold" Foreground="#2E6D36" Text="{Binding TotalDurationText}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,8,0,0" Foreground="#5B5B5B" Text="{Binding PeriodText}" />
                                            <TextBlock Margin="0,8,0,0" Foreground="#5B5B5B" Text="{Binding ProgramSummaryText}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
