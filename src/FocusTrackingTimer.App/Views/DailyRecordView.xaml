<UserControl x:Class="FocusTrackingTimer.App.Views.DailyRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel}"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#5B5B5B"
                               Text="{Binding DisplayedRecordMonthText, StringFormat={}{0} 요약}" />

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <ComboBox Padding="8"
                                  BorderBrush="#2F2F2F"
                                  BorderThickness="2"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding RecordFilterOptions}"
                                  SelectedItem="{Binding SelectedRecordFilter, Mode=TwoWay}"
                                  SelectionChanged="RecordFilter_SelectionChanged" />
                    </StackPanel>
                </Grid>

                <UniformGrid Grid.Row="1"
                             Margin="0,18,0,0"
                             Columns="5">
                    <Border Margin="0,0,10,0"
                            Padding="14"
                            Background="#F7F7F4"
                            BorderBrush="#D5D5D5"
                            BorderThickness="1.5"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#6B6B66"
                                       Text="작업한 날짜 수" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Text="{Binding MonthlyWorkedDayCountText}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,10,0"
                            Padding="14"
                            Background="#F7F7F4"
                            BorderBrush="#D5D5D5"
                            BorderThickness="1.5"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#6B6B66"
                                       Text="월간 총 작업 시간" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Text="{Binding MonthlyTotalWallClockDurationText}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,10,0"
                            Padding="14"
                            Background="#F7F7F4"
                            BorderBrush="#D5D5D5"
                            BorderThickness="1.5"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#6B6B66"
                                       Text="월간 총 집중 시간" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#2E6D36"
                                       Text="{Binding MonthlyTotalFocusDurationText}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,10,0"
                            Padding="14"
                            Background="#F7F7F4"
                            BorderBrush="#D5D5D5"
                            BorderThickness="1.5"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#6B6B66"
                                       Text="일간 평균 작업 시간" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Text="{Binding MonthlyAverageWallClockDurationText}" />
                        </StackPanel>
                    </Border>

                    <Border Padding="14"
                            Background="#F7F7F4"
                            BorderBrush="#D5D5D5"
                            BorderThickness="1.5"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#6B6B66"
                                       Text="일간 평균 집중 시간" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#2E6D36"
                                       Text="{Binding MonthlyAverageFocusDurationText}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="672" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="672"
                    MinHeight="584"
                    Style="{StaticResource Panel}"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <Button Width="54"
                                    Height="32"
                                    Margin="0,0,8,0"
                                    Background="#FFFFFF"
                                    BorderBrush="#D7D7D0"
                                    BorderThickness="1.5"
                                    Click="PreviousRecordYearButton_Click"
                                    Content="-1Y" />
                            <Button Width="32"
                                    Height="32"
                                    Background="#FFFFFF"
                                    BorderBrush="#D7D7D0"
                                    BorderThickness="1.5"
                                    Click="PreviousRecordMonthButton_Click"
                                    Content="&lt;" />
                            <Button Width="64"
                                    Height="32"
                                    Margin="8,0,0,0"
                                    Background="#FFFFFF"
                                    BorderBrush="#D7D7D0"
                                    BorderThickness="1.5"
                                    Click="CurrentRecordMonthButton_Click"
                                    Content="이번 달" />
                            <TextBlock Margin="12,0"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding DisplayedRecordMonthText}" />
                            <Button Width="32"
                                    Height="32"
                                    Background="#FFFFFF"
                                    BorderBrush="#D7D7D0"
                                    BorderThickness="1.5"
                                    Click="NextRecordMonthButton_Click"
                                    Content="&gt;" />
                            <Button Width="54"
                                    Height="32"
                                    Margin="8,0,0,0"
                                    Background="#FFFFFF"
                                    BorderBrush="#D7D7D0"
                                    BorderThickness="1.5"
                                    Click="NextRecordYearButton_Click"
                                    Content="+1Y" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Width="630"
                            Margin="0,18,0,0"
                            Padding="8,6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#F5F5F0"
                            BorderBrush="#E0E0D8"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <UniformGrid Columns="7">
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#A65A5A"
                                           Text="일" />
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#7A7A74"
                                           Text="월" />
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#7A7A74"
                                           Text="화" />
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#7A7A74"
                                           Text="수" />
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#7A7A74"
                                           Text="목" />
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#7A7A74"
                                           Text="금" />
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#7A7A74"
                                           Text="토" />
                            </UniformGrid>

                            <ItemsControl Margin="0,8,0,0"
                                          ItemsSource="{Binding CalendarRows}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="7" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FocusVisualStyle="{x:Null}"
                                                Focusable="False"
                                                Click="CalendarDayButton_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="IsEnabled" Value="True" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="CellChrome"
                                                                        Width="82"
                                                                        Height="78"
                                                                        Margin="4,1,4,1"
                                                                        Padding="4"
                                                                        Background="Transparent"
                                                                        BorderBrush="#FFFFFF"
                                                                        BorderThickness="0"
                                                                        CornerRadius="18">
                                                                    <Grid>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="28" />
                                                                            <RowDefinition Height="18" />
                                                                            <RowDefinition Height="18" />
                                                                        </Grid.RowDefinitions>

                                                                        <Ellipse Grid.Row="0"
                                                                                 Width="{Binding DotSize}"
                                                                                 Height="{Binding DotSize}"
                                                                                 HorizontalAlignment="Center"
                                                                                 VerticalAlignment="Center"
                                                                                 Fill="#26C567">
                                                                            <Ellipse.Style>
                                                                                <Style TargetType="Ellipse">
                                                                                    <Setter Property="Opacity" Value="0" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasDuration}" Value="True">
                                                                                            <Setter Property="Opacity" Value="1" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Ellipse.Style>
                                                                        </Ellipse>

                                                                        <TextBlock Grid.Row="1"
                                                                                   HorizontalAlignment="Center"
                                                                                   FontSize="9"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="#2E6D36"
                                                                                   Text="{Binding DurationText}">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Opacity" Value="0" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasDuration}" Value="True">
                                                                                            <Setter Property="Opacity" Value="1" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>

                                                                        <TextBlock Grid.Row="2"
                                                                                   HorizontalAlignment="Center"
                                                                                   FontSize="12"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding DayText}">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#2F2F2F" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsSunday}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#D95148" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#2E6D36" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Grid>
                                                                </Border>

                                                                <ControlTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                                                        <Setter TargetName="CellChrome" Property="Opacity" Value="0" />
                                                                        <Setter Property="IsEnabled" Value="False" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding HasDuration}" Value="False">
                                                                        <Setter Property="IsEnabled" Value="False" />
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="CellChrome" Property="Background" Value="#E7E7E1" />
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter TargetName="CellChrome" Property="Background" Value="#FFFFFF" />
                                                                        <Setter TargetName="CellChrome" Property="BorderThickness" Value="1.5" />
                                                                    </DataTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    MinHeight="584"
                    Style="{StaticResource Panel}"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Text="선택한 날짜 요약" />
                    <TextBlock Grid.Row="1"
                               Margin="0,16,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="{Binding SelectedDailyDateText}" />

                    <StackPanel Grid.Row="2"
                                Margin="0,12,0,0">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{Binding SelectedDailyTotalDurationText, StringFormat=총 작업 시간: {0}}" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{Binding SelectedDailyFocusRatioText, StringFormat=경과 시간 대비 집중 시간: {0}}" />
                    </StackPanel>

                    <Grid Grid.Row="3"
                          Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="작업 기록" />

                        <Grid Grid.Row="1"
                              Margin="0,8,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SelectedDailyRecordRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="14"
                                                    Background="#F7F7F4"
                                                    BorderBrush="#D5D5D5"
                                                    BorderThickness="1.5"
                                                    CornerRadius="10">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Left"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding ProjectName}" />
                                                        <TextBlock HorizontalAlignment="Right"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#2E6D36"
                                                                   Text="{Binding DurationText}" />
                                                    </DockPanel>
                                                    <TextBlock Margin="0,8,0,0"
                                                               Foreground="#6B6B66"
                                                               Text="{Binding PeriodText}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock VerticalAlignment="Bottom"
                                       Foreground="#7A7A74"
                                       Text="{Binding SelectedDailyEmptyText}"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
