<UserControl x:Class="FocusTrackingTimer.App.Views.Timer.RegisteredProgramListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="20,16"
            Background="{StaticResource ThemeTransparentBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,16,0">
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="Black"
                               Text="등록 프로그램" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource ThemeSecondaryTextBrush}"
                               Text="작업 탭에서는 실행 중인 세션의 상태만 확인합니다. 종료된 프로그램별 시간은 기록 탭에서 확인합니다."
                               TextWrapping="Wrap" />
                </StackPanel>

                <ComboBox Grid.Column="1"
                          Margin="0,2,10,0"
                          Style="{StaticResource FilterComboBox}"
                          DisplayMemberPath="Label"
                          ItemsSource="{Binding ProgramSortOptions}"
                          SelectedItem="{Binding SelectedProgramSortOption, Mode=TwoWay}"
                          SelectionChanged="ProgramSort_SelectionChanged" />
                <Button Grid.Column="2"
                        Height="32"
                        Margin="0,2,0,0"
                        Padding="10,0"
                        Style="{StaticResource PrimaryButton}"
                        Click="OpenProgramManagerButton_Click"
                        Content="프로그램 추가" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="0,18,0,0"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding RegisteredProgramRows}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,9"
                                    BorderBrush="{StaticResource ThemeHoverBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource ThemeTransparentBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource ThemeSelectionBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource HoverActionButton}"
                                                Click="DeleteProgramButton_Click">
                                            <Image Width="18"
                                                   Height="18"
                                                   Source="/Assets/delete.png"
                                                   Stretch="Uniform" />
                                        </Button>
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource HoverActionButton}"
                                                Click="EditProgramButton_Click">
                                            <Image Width="18"
                                                   Height="18"
                                                   Source="/Assets/edit.png"
                                                   Stretch="Uniform" />
                                        </Button>
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource HoverActionButton}"
                                                Click="FocusRegisteredProgramButton_Click">
                                            <Image Width="20"
                                                   Height="20"
                                                   Source="/Assets/view.png"
                                                   Stretch="Uniform" />
                                        </Button>
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource HoverActionButton}"
                                                Click="PinProgramButton_Click">
                                            <Image Width="20"
                                                   Height="20"
                                                   SnapsToDevicePixels="True"
                                                   UseLayoutRounding="True"
                                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                   Stretch="Uniform">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Source" Value="/Assets/pin.png" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                <Setter Property="Source" Value="/Assets/pin-filled.png" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Button>

                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10"
                                                     Height="10"
                                                     Margin="0,6,10,0"
                                                     VerticalAlignment="Top"
                                                     Fill="{Binding StatusBrush}"
                                                     ToolTip="{Binding StatusText}" />
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource ThemePrimaryTextBrush}"
                                                               Text="{Binding DisplayName}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <Image Width="20"
                                                           Height="20"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Source="/Assets/pin-filled.png"
                                                           SnapsToDevicePixels="True"
                                                           UseLayoutRounding="True"
                                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                           Stretch="Uniform"
                                                           Visibility="{Binding PinIconVisibility}" />
                                                </StackPanel>
                                                <TextBlock Margin="0,3,0,0"
                                                           Foreground="{StaticResource ThemeSecondaryTextBrush}"
                                                           Text="{Binding ProcessName}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Grid.Column="1"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ThemeFocusBrush}"
                                               Text="{Binding FocusDurationText}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
