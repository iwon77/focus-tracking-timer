<UserControl x:Class="FocusTrackingTimer.App.Views.Timer.ProjectSidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="ProjectListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource ThemeTransparentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="ProjectListItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="{StaticResource ThemeTransparentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="14,7"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ThemeLightSurfaceBrush}" />
                                <Setter Property="Foreground" Value="Black" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ThemeSelectionBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Padding="0"
            Background="{StaticResource ThemeTransparentBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"
                               SharedSizeGroup="TimerTopSection" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="12"
                    Background="{StaticResource ThemeTransparentBrush}"
                    BorderThickness="0">
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Width="184"
                          Margin="6,0">
                        <TextBlock Margin="0,0,36,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="Black"
                                   VerticalAlignment="Center"
                                   Text="{Binding RunningProjectNameText}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Width="28"
                                Height="28"
                                HorizontalAlignment="Right"
                                Style="{StaticResource StaticActionIconButton}"
                                Click="OpenRunningProjectSummaryPipButton_Click"
                                Visibility="{Binding RunningProjectSummaryPipButtonVisibility}">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource CommonToolTipStyle}"
                                         Content="팝업으로 보기" />
                            </Button.ToolTip>
                            <Image Width="20"
                                   Height="20"
                                   Source="/Assets/pip.png"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Stretch="Uniform" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeSecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Text="경과 시간" />
                            <TextBlock Margin="0,6,0,0"
                                       Width="86"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemePrimaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Text="{Binding RunningProjectWallClockText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeSecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Text="집중 시간" />
                            <TextBlock Margin="0,6,0,0"
                                       Width="86"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeFocusBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Text="{Binding RunningProjectFocusText}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="12,0"
                    Style="{StaticResource SectionHorizontalDivider}" />

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Margin="14,10,14,8"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="Black"
                               Text="고정 작업" />

                    <ListBox Background="{StaticResource ThemeTransparentBrush}"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ItemsSource="{Binding PinnedProjectRows}"
                             SelectedItem="{Binding SelectedProjectRow, Mode=TwoWay}"
                             SelectionChanged="ProjectList_SelectionChanged"
                             ItemContainerStyle="{StaticResource ProjectListItemStyle}"
                             Style="{StaticResource ProjectListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">
                                    <Button x:Name="PinnedProjectPinButton"
                                            DockPanel.Dock="Right"
                                            Width="28"
                                            Height="28"
                                            Margin="6,0,0,0"
                                            Padding="4"
                                            Style="{StaticResource StaticActionIconButton}"
                                            Click="PinProjectRowButton_Click"
                                            Foreground="{StaticResource ThemeHintTextBrush}">
                                        <Image Width="20"
                                               Height="20"
                                               Source="/Assets/pin-filled.png"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                                               Stretch="Uniform" />
                                    </Button>
                                    <TextBlock VerticalAlignment="Center"
                                               MaxWidth="150"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <DockPanel Margin="14,14,14,8"
                               LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Width="18"
                                Height="18"
                                Style="{StaticResource StaticActionIconButton}"
                                Click="AddProjectButton_Click"
                                Foreground="{StaticResource ThemePrimaryTextBrush}">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource CommonToolTipStyle}"
                                         Content="작업 추가" />
                            </Button.ToolTip>
                            <Image Width="14"
                                   Height="14"
                                   Source="/Assets/add.png"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Stretch="Uniform" />
                        </Button>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="Black"
                                   Text="작업 목록" />
                    </DockPanel>

                    <ListBox Background="{StaticResource ThemeTransparentBrush}"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ItemsSource="{Binding ProjectRows}"
                             SelectedItem="{Binding SelectedProjectRow, Mode=TwoWay}"
                             SelectionChanged="ProjectList_SelectionChanged"
                             ItemContainerStyle="{StaticResource ProjectListItemStyle}"
                             Style="{StaticResource ProjectListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">
                                    <Button x:Name="ProjectPinButton"
                                            DockPanel.Dock="Right"
                                            Width="28"
                                            Height="28"
                                            Margin="6,0,0,0"
                                            Padding="4"
                                            Style="{StaticResource StaticActionIconButton}"
                                            Click="PinProjectRowButton_Click"
                                            Foreground="{StaticResource ThemeHintTextBrush}"
                                            Opacity="0"
                                            IsHitTestVisible="False">
                                        <Image Width="20"
                                               Height="20"
                                               Source="/Assets/pin.png"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                                               Stretch="Uniform" />
                                    </Button>
                                    <TextBlock VerticalAlignment="Center"
                                               MaxWidth="150"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                        <Setter TargetName="ProjectPinButton" Property="Opacity" Value="1" />
                                        <Setter TargetName="ProjectPinButton" Property="IsHitTestVisible" Value="True" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
