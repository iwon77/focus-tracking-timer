<UserControl x:Class="FocusTrackingTimer.App.Views.Timer.ProjectSidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="ProjectListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource ThemeTransparentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="ProjectListItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Background" Value="{StaticResource ThemeTransparentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="14,7"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ThemeSelectionBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource ThemeFocusBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ThemeSelectionBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Padding="0"
            Background="{StaticResource ThemeTransparentBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"
                               SharedSizeGroup="TimerTopSection" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="12"
                    Background="{StaticResource ThemeTransparentBrush}"
                    BorderThickness="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            Background="{StaticResource ThemeTransparentBrush}"
                            BorderBrush="{StaticResource ThemeTransparentBrush}"
                            BorderThickness="0"
                            Click="OpenRunningProjectSummaryPipButton_Click"
                            Padding="0"
                            Visibility="{Binding RunningProjectSummaryPipButtonVisibility}"
                            ToolTip="Open running summary PIP">
                        <Image Width="24"
                               Height="24"
                               Source="/Assets/current-session-pip.png"
                               Stretch="Uniform" />
                    </Button>

                    <Grid Grid.Row="1"
                          Margin="0,12,0,0">
                        <TextBlock Margin="0,0,8,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Top"
                                   Text="{Binding RunningProjectNameText}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeSecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Text="경과 시간" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemePrimaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Text="{Binding RunningProjectWallClockText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeSecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Text="집중 시간" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeFocusBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Text="{Binding RunningProjectFocusText}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="12,0"
                    Style="{StaticResource SectionHorizontalDivider}" />

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Margin="14,10,14,8"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{StaticResource ThemeSecondaryTextBrush}"
                               Text="고정 작업" />

                    <ListBox Background="{StaticResource ThemeTransparentBrush}"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ItemsSource="{Binding PinnedProjectRows}"
                             SelectedItem="{Binding SelectedProjectRow, Mode=TwoWay}"
                             SelectionChanged="ProjectList_SelectionChanged"
                             ItemContainerStyle="{StaticResource ProjectListItemStyle}"
                             Style="{StaticResource ProjectListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">
                                    <Button x:Name="PinnedProjectPinButton"
                                            DockPanel.Dock="Right"
                                            Width="22"
                                            Height="22"
                                            Margin="6,0,0,0"
                                            Background="{StaticResource ThemeTransparentBrush}"
                                            BorderThickness="0"
                                            Click="PinProjectRowButton_Click"
                                            Content="★"
                                            Foreground="{StaticResource ThemeHintTextBrush}"
                                            ToolTip="작업 고정" />
                                    <TextBlock VerticalAlignment="Center"
                                               MaxWidth="150"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <DockPanel Margin="14,14,14,8"
                               LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Width="18"
                                Height="18"
                                Style="{StaticResource SecondaryButton}"
                                Click="AddProjectButton_Click"
                                Content="+"
                                Foreground="{StaticResource ThemePrimaryTextBrush}" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource ThemeSecondaryTextBrush}"
                                   Text="작업 목록" />
                    </DockPanel>

                    <ListBox Background="{StaticResource ThemeTransparentBrush}"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ItemsSource="{Binding ProjectRows}"
                             SelectedItem="{Binding SelectedProjectRow, Mode=TwoWay}"
                             SelectionChanged="ProjectList_SelectionChanged"
                             ItemContainerStyle="{StaticResource ProjectListItemStyle}"
                             Style="{StaticResource ProjectListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">
                                    <Button x:Name="ProjectPinButton"
                                            DockPanel.Dock="Right"
                                            Width="22"
                                            Height="22"
                                            Margin="6,0,0,0"
                                            Background="{StaticResource ThemeTransparentBrush}"
                                            BorderThickness="0"
                                            Click="PinProjectRowButton_Click"
                                            Content="★"
                                            Foreground="{StaticResource ThemeHintTextBrush}"
                                            ToolTip="작업 고정"
                                            Opacity="0"
                                            IsEnabled="False" />
                                    <TextBlock VerticalAlignment="Center"
                                               MaxWidth="150"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                        <Setter TargetName="ProjectPinButton" Property="Opacity" Value="1" />
                                        <Setter TargetName="ProjectPinButton" Property="IsEnabled" Value="True" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
