<UserControl x:Class="FocusTrackingTimer.App.Views.Timer.ProjectSidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="16" Background="#EFEFEB">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,14"
                    Padding="12"
                    Background="#FFFFFF"
                    BorderBrush="#D7D7D0"
                    BorderThickness="1.5"
                    CornerRadius="12"
                    Cursor="Hand"
                    MouseLeftButtonUp="RunningProjectSummary_MouseLeftButtonUp">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding RunningProjectNameText}"
                               TextTrimming="CharacterEllipsis" />

                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#5B5B5B"
                                       Text="경과 시간" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1F1F1F"
                                       Text="{Binding RunningProjectWallClockText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#5B5B5B"
                                       Text="집중 시간" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#2EAD62"
                                       Text="{Binding RunningProjectFocusText}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <DockPanel Grid.Row="1" Margin="0,0,0,10" LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Width="28"
                        Height="26"
                        Background="#1F1F1F"
                        BorderBrush="#1F1F1F"
                        BorderThickness="1.5"
                        Click="AddProjectButton_Click"
                        Content="+"
                        Foreground="#FFFFFF" />
                <ComboBox DockPanel.Dock="Right"
                          Width="84"
                          Height="28"
                          Margin="0,0,8,0"
                          Padding="6,2"
                          BorderBrush="#D7D7D0"
                          BorderThickness="1.5"
                          DisplayMemberPath="Label"
                          ItemsSource="{Binding ProjectSortOptions}"
                          SelectedItem="{Binding SelectedProjectSortOption, Mode=TwoWay}"
                          SelectionChanged="ProjectSort_SelectionChanged" />
                <TextBlock VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="프로젝트 목록" />
            </DockPanel>

            <ListBox Grid.Row="2"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     HorizontalContentAlignment="Stretch"
                     ItemsSource="{Binding ProjectRows}"
                     SelectedItem="{Binding SelectedProjectRow, Mode=TwoWay}"
                     SelectionChanged="ProjectList_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,2" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Padding="10,8"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#E6E6E2" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#E6E6E2" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel LastChildFill="True">
                            <Button x:Name="ProjectPinButton"
                                    DockPanel.Dock="Right"
                                    Width="22"
                                    Height="22"
                                    Margin="6,0,0,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="PinProjectRowButton_Click"
                                    Content="⌖"
                                    Foreground="#5B5B5B"
                                    ToolTip="프로젝트 고정"
                                    IsEnabled="True"
                                    Opacity="1" />
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#3F3F3F"
                                       Text="{Binding Name}"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsPinned}" Value="False">
                                <Setter TargetName="ProjectPinButton" Property="Opacity" Value="0" />
                                <Setter TargetName="ProjectPinButton" Property="IsEnabled" Value="False" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                <Setter TargetName="ProjectPinButton" Property="Opacity" Value="1" />
                                <Setter TargetName="ProjectPinButton" Property="IsEnabled" Value="True" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
