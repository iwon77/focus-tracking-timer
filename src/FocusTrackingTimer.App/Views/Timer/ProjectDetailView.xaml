<UserControl x:Class="FocusTrackingTimer.App.Views.Timer.ProjectDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="20,16"
            Background="{StaticResource ThemeSurfaceBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="118" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock MaxWidth="360"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemePrimaryTextBrush}"
                               Text="{Binding SelectedProjectTitle}"
                               TextTrimming="CharacterEllipsis" />
                    <Button Width="28"
                            Height="26"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButton}"
                            Click="EditSelectedProjectButton_Click"
                            Content="✎"
                            IsEnabled="{Binding IsProjectEditEnabled}" />
                    <Button Width="28"
                            Height="26"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButton}"
                            Click="DeleteProjectButton_Click"
                            Content="✕"
                            IsEnabled="{Binding IsProjectDeleteEnabled}" />
                    <Button Width="42"
                            Height="26"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButton}"
                            Click="MemoSelectedProjectButton_Click"
                            Content="메모"
                            IsEnabled="{Binding IsProjectMemoEnabled}" />
                </StackPanel>

                <TextBlock Margin="0,8,0,0"
                           Foreground="{StaticResource ThemeSecondaryTextBrush}"
                           Text="{Binding ActiveSessionPeriodText}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ThemeSecondaryTextBrush}"
                           Text="오늘 누적 시간" />
                <TextBlock Margin="0,6,0,0"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ThemePrimaryTextBrush}"
                           Text="{Binding SelectedProjectTodayText}" />
            </StackPanel>

            <StackPanel Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Width="96"
                        Height="38"
                        Background="{Binding TimerActionButtonBackground}"
                        BorderBrush="{StaticResource ThemeActiveBrush}"
                        BorderThickness="1"
                        Click="TimerActionButton_Click"
                        Content="{Binding TimerActionButtonText}"
                        FontSize="16"
                        Foreground="{Binding TimerActionButtonForeground}"
                        FontWeight="SemiBold"
                        IsEnabled="{Binding IsTimerActionEnabled}" />
                <Button Width="96"
                        Height="38"
                        Margin="0,8,0,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="StopTimerButton_Click"
                        Content="중지"
                        IsEnabled="{Binding IsTimerStopEnabled}" />
            </StackPanel>

        </Grid>
    </Border>
</UserControl>
