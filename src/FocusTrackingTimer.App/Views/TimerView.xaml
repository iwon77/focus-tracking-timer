<UserControl x:Class="FocusTrackingTimer.App.Views.TimerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:timerViews="clr-namespace:FocusTrackingTimer.App.Views.Timer">
    <Border Style="{StaticResource Panel}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <timerViews:ProjectSidebarView Grid.Column="0" />

            <Border Grid.Column="1"
                    Style="{StaticResource Divider}" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <timerViews:ProjectDetailView Grid.Row="0" />

                <Border Grid.Row="1"
                        Style="{StaticResource Divider}" />

                <timerViews:RegisteredProgramListView Grid.Row="2" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
