<UserControl x:Class="FocusTrackingTimer.App.Views.WeeklyRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border Style="{StaticResource Panel}" Padding="20">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="주간 기록" />
                <TextBlock Margin="0,10,0,0"
                           Foreground="#5B5B5B"
                           Text="주간 기록 화면은 우선 빈 화면으로 제공합니다. 상세 요약과 목록은 다음 작업에서 추가합니다."
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
