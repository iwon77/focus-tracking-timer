<UserControl x:Class="FocusTrackingTimer.App.Views.WeeklyRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="WeeklyDurationTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource Panel}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="508" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel HorizontalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Width="44" Height="32" Style="{StaticResource SecondaryButton}" Click="PreviousWeekButton_Click" Content="&lt;" />
                    <TextBlock Margin="14,0" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="{Binding DisplayedWeekLabelText}" />
                    <Button Width="44" Height="32" Style="{StaticResource SecondaryButton}" Click="NextWeekButton_Click" Content="&gt;" />
                    <Button Width="72" Height="32" Margin="8,0,0,0" Style="{StaticResource SecondaryButton}" Click="CurrentWeekButton_Click" Content="이번 주" />
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              Margin="0,18,0,16"
                              ItemsSource="{Binding WeeklyDayBubbleRows}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Padding="0"
                                    Background="{StaticResource ThemeTransparentBrush}"
                                    BorderThickness="0"
                                    FocusVisualStyle="{x:Null}"
                                    Focusable="False"
                                    Click="WeeklySummaryDayButton_Click"
                                    IsEnabled="{Binding HasBubble}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Button.Template>
                                <Border Padding="8"
                                        Margin="2"
                                        CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource ThemeTransparentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource ThemeSelectionBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource ThemeActiveBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding DayOfWeekText}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource ThemeSecondaryTextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSunday}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource ThemeSundayBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource ThemeActiveTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Grid Width="34"
                                              Height="22"
                                              Margin="0,8,0,8">
                                            <Border Height="{Binding BubbleDiameter}"
                                                    VerticalAlignment="Bottom"
                                                    Background="{StaticResource ThemeFocusBrush}"
                                                    CornerRadius="3"
                                                    Visibility="{Binding BubbleVisibility}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Opacity" Value="0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding BubbleDiameter}" Value="8">
                                                                <Setter Property="Opacity" Value="0.35" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding BubbleDiameter}" Value="11">
                                                                <Setter Property="Opacity" Value="0.5" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding BubbleDiameter}" Value="14">
                                                                <Setter Property="Opacity" Value="0.65" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding BubbleDiameter}" Value="17">
                                                                <Setter Property="Opacity" Value="0.8" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding BubbleDiameter}" Value="20">
                                                                <Setter Property="Opacity" Value="1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Grid>
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding DateText}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource ThemePrimaryTextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSunday}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource ThemeSundayBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource ThemeActiveTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <UniformGrid Grid.Row="2"
                             Columns="4"
                             Margin="0,0,0,18">
                    <Border Margin="0,0,8,0" Padding="12" Background="{StaticResource ThemeLightSurfaceBrush}" CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="총 작업 수" />
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" FontWeight="SemiBold" Text="{Binding WeeklyRecordCountText}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,0" Padding="12" Background="{StaticResource ThemeLightSurfaceBrush}" CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="총 작업 시간" />
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" FontWeight="SemiBold" Text="{Binding WeekTotalWallClockDurationText}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,0" Padding="12" Background="{StaticResource ThemeLightSurfaceBrush}" CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="누적 집중" />
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" FontWeight="SemiBold" Foreground="{StaticResource ThemeFocusBrush}" Text="{Binding WeekTotalFocusDurationText}" />
                        </StackPanel>
                    </Border>
                    <Border Padding="12" Background="{StaticResource ThemeLightSurfaceBrush}" CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="평균 집중" />
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" FontWeight="SemiBold" Foreground="{StaticResource ThemeFocusBrush}" Text="{Binding AverageDailyFocusDurationText}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="주간 기록 리스트" />

                    <ListBox x:Name="WeeklyRecordListControl"
                             Grid.Row="1"
                             Margin="0,10,0,0"
                             Background="{StaticResource ThemeTransparentBrush}"
                             BorderThickness="0"
                             ItemsSource="{Binding WeeklyRecordRows}"
                             SelectedItem="{Binding SelectedWeeklyRecordRow, Mode=TwoWay}"
                             SelectionChanged="WeeklyRecordList_SelectionChanged">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,14,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource WeeklyDurationTextStyle}" Text="{Binding Items[0].GroupTotalDurationText}" />
                                                <TextBlock Margin="8,0,0,0" Style="{StaticResource WeeklyDurationTextStyle}" Foreground="{StaticResource ThemeFocusBrush}" Text="{Binding Items[0].GroupFocusDurationText}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Padding="8,10"
                                                    Background="{StaticResource ThemeTransparentBrush}"
                                                    BorderBrush="{StaticResource ThemeHoverBorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ThemeSelectionBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ThemeSelectionBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Width="8" Height="8" Margin="0,6,10,0" Fill="{StaticResource ThemeStatusBrush}" VerticalAlignment="Top" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding ProjectName}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,5,0,0" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="{Binding PeriodText}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="4,0,14,0" HorizontalAlignment="Right">
                                        <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold" Text="{Binding TotalDurationText}" />
                                        <TextBlock Margin="0,5,0,0" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{StaticResource ThemeFocusBrush}" Text="{Binding FocusDurationText}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>

            <Border Grid.Column="1"
                    Style="{StaticResource Divider}" />

            <Grid Grid.Column="2"
                  Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource TagBadge}">
                    <TextBlock Foreground="{StaticResource ThemeTagTextBrush}"
                               FontWeight="SemiBold"
                               Text="작업 상세" />
                </Border>
                <TextBlock Grid.Row="1"
                           Margin="0,12,0,0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Text="{Binding SelectedRecordTitle}" />
                <TextBlock Grid.Row="2"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource ThemeSecondaryTextBrush}"
                           Text="{Binding SelectedRecordSubtitle}" />

                <Grid Grid.Row="3"
                      Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <UniformGrid Columns="2"
                                 Width="288"
                                 HorizontalAlignment="Left"
                                 Margin="0,0,0,16">
                        <Border Margin="0,0,8,0" Padding="12" Background="{StaticResource ThemeLightSurfaceBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="작업 시간" />
                                <TextBlock Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedRecordTotalDurationText}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="12" Background="{StaticResource ThemeLightSurfaceBrush}" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="집중 시간" />
                                <TextBlock Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource ThemeFocusBrush}" Text="{Binding SelectedRecordFocusDurationText}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedRecordProgramRows}"
                                      Visibility="{Binding SelectedRecordDetailVisibility}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,10"
                                            BorderBrush="{StaticResource ThemeHoverBorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Width="8" Height="8" Margin="0,6,10,0" Fill="{StaticResource ThemeStatusBrush}" VerticalAlignment="Top" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="0,5,0,0" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="{Binding ProcessName}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Margin="4,0,14,0" FontWeight="SemiBold" Foreground="{StaticResource ThemeFocusBrush}" Text="{Binding DurationText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <TextBlock Grid.Row="4"
                           Margin="0,16,0,0"
                           Foreground="{StaticResource ThemeHintTextBrush}"
                           Visibility="{Binding SelectedRecordEmptyVisibility}"
                           Text="{Binding SelectedRecordEmptyText}"
                           TextWrapping="Wrap" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
