<Window x:Class="FocusTrackingTimer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FocusTrackingTimer.App.Views"
        mc:Ignorable="d"
        Title="Focus Tracking Timer"
        Width="1120"
        Height="720"
        MinWidth="1120"
        MinHeight="720"
        Background="#F7F7F4">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel}" Padding="8" Background="#FFFFFF">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <Button x:Name="ProjectTabButtonControl"
                        Width="120"
                        Margin="0,0,10,0"
                        Padding="10,6"
                        Background="{Binding ProjectTabBackground}"
                        BorderBrush="#2F2F2F"
                        BorderThickness="2"
                        Click="ProjectTabButton_Click"
                        Content="타이머"
                        Foreground="{Binding ProjectTabForeground}" />
                <Button x:Name="CalendarTabButtonControl"
                        Width="120"
                        Padding="10,6"
                        Background="{Binding RecordTabBackground}"
                        BorderBrush="#2F2F2F"
                        BorderThickness="2"
                        Click="CalendarTabButton_Click"
                        Content="일간기록"
                        Foreground="{Binding RecordTabForeground}" />
                <Button x:Name="WeeklyTabButtonControl"
                        Width="120"
                        Margin="10,0,0,0"
                        Padding="10,6"
                        Background="{Binding WeeklyTabBackground}"
                        BorderBrush="#2F2F2F"
                        BorderThickness="2"
                        Click="WeeklyTabButton_Click"
                        Content="주간기록"
                        Foreground="{Binding WeeklyTabForeground}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <views:TimerView Visibility="{Binding ProjectViewVisibility}" />
            <views:DailyRecordView Visibility="{Binding RecordViewVisibility}" />
            <views:WeeklyRecordView Visibility="{Binding WeeklyViewVisibility}" />
        </Grid>
    </Grid>
</Window>
