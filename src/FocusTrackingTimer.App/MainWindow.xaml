<Window x:Class="FocusTrackingTimer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FocusTrackingTimer.App.Views"
        mc:Ignorable="d"
        Title="Focus Tracking Timer"
        Width="920"
        Height="720"
        MinWidth="1040"
        MinHeight="700"
        Background="{StaticResource ThemeBaseBackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="12,5"
                Background="{StaticResource ThemeSurfaceBrush}"
                BorderBrush="{StaticResource ThemeSecondaryBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Right"
                        Width="84"
                        Height="32"
                        Margin="10,0,0,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="OpenPerformanceMonitorButton_Click"
                        Content="성능" />

                <ComboBox DockPanel.Dock="Right"
                          Width="220"
                          Style="{StaticResource FilterComboBox}"
                          DisplayMemberPath="Label"
                          ItemsSource="{Binding DailyRecord.RecordFilterOptions}"
                          SelectedItem="{Binding DailyRecord.SelectedRecordFilter, Mode=TwoWay}"
                          SelectionChanged="RecordFilter_SelectionChanged"
                          Visibility="{Binding Menu.DailyRecordViewVisibility}" />

                <ComboBox DockPanel.Dock="Right"
                          Width="220"
                          Style="{StaticResource FilterComboBox}"
                          DisplayMemberPath="Label"
                          ItemsSource="{Binding WeeklyRecord.RecordFilterOptions}"
                          SelectedItem="{Binding WeeklyRecord.SelectedRecordFilter, Mode=TwoWay}"
                          SelectionChanged="WeeklyRecordFilter_SelectionChanged"
                          Visibility="{Binding Menu.WeeklyRecordViewVisibility}" />

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button x:Name="ProjectTabButtonControl"
                            Margin="0,0,6,0"
                            Style="{StaticResource MenuTabButton}"
                            Padding="18,7"
                            Background="{Binding Menu.TimerTabBackground}"
                            BorderBrush="{StaticResource ThemeTransparentBrush}"
                            BorderThickness="0"
                            Click="ProjectTabButton_Click"
                            Content="타이머"
                            Foreground="{Binding Menu.TimerTabForeground}" />
                    <Button x:Name="CalendarTabButtonControl"
                            Margin="0,0,6,0"
                            Style="{StaticResource MenuTabButton}"
                            Padding="18,7"
                            Background="{Binding Menu.DailyRecordTabBackground}"
                            BorderBrush="{StaticResource ThemeTransparentBrush}"
                            BorderThickness="0"
                            Click="CalendarTabButton_Click"
                            Content="일간 기록"
                            Foreground="{Binding Menu.DailyRecordTabForeground}" />
                    <Button x:Name="WeeklyTabButtonControl"
                            Style="{StaticResource MenuTabButton}"
                            Padding="18,7"
                            Background="{Binding Menu.WeeklyRecordTabBackground}"
                            BorderBrush="{StaticResource ThemeTransparentBrush}"
                            BorderThickness="0"
                            Click="WeeklyTabButton_Click"
                            Content="주간 기록"
                            Foreground="{Binding Menu.WeeklyRecordTabForeground}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <views:TimerView DataContext="{Binding Timer}"
                             Visibility="{Binding DataContext.Menu.TimerViewVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
            <views:DailyRecordView DataContext="{Binding DailyRecord}"
                                   Visibility="{Binding DataContext.Menu.DailyRecordViewVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
            <views:WeeklyRecordView DataContext="{Binding WeeklyRecord}"
                                    Visibility="{Binding DataContext.Menu.WeeklyRecordViewVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
        </Grid>
    </Grid>
</Window>
