<Window x:Class="FocusTrackingTimer.App.ProgramManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="프로그램 추가"
        Width="760"
        Height="640"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F7F7F4">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22"
                   FontWeight="SemiBold"
                   Text="{Binding TitleText}" />

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                Padding="16"
                Background="#FFFFFF"
                BorderBrush="#D7D7D0"
                BorderThickness="1.5"
                CornerRadius="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="76" />
                </Grid.ColumnDefinitions>

                <TextBox Padding="10,7"
                         BorderBrush="#D7D7D0"
                         BorderThickness="1.5"
                         Text="{Binding ManualExecutableInput, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Background="#FFFFFF"
                        BorderBrush="#D7D7D0"
                        BorderThickness="1.5"
                        Click="BrowseButton_Click"
                        Content="파일" />
                <Button Grid.Column="2"
                        Margin="8,0,0,0"
                        Background="#1F1F1F"
                        BorderBrush="#1F1F1F"
                        BorderThickness="1.5"
                        Click="AddManualButton_Click"
                        Content="등록"
                        Foreground="#FFFFFF" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0,0,0,10"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Text="실행 중인 프로그램" />

        <Border Grid.Row="3"
                Padding="16"
                Background="#FFFFFF"
                BorderBrush="#D7D7D0"
                BorderThickness="1.5"
                CornerRadius="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding RunningProcesses}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="12"
                                    Background="#FFFFFF"
                                    BorderBrush="#D7D7D0"
                                    BorderThickness="1.5"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                        <TextBlock Margin="0,4,0,0" Foreground="#5B5B5B" Text="{Binding ProcessName}" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Padding="14,7"
                                            Background="#1F1F1F"
                                            BorderBrush="#1F1F1F"
                                            BorderThickness="1.5"
                                            Click="AddDetectedButton_Click"
                                            Content="추가"
                                            Foreground="#FFFFFF" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
