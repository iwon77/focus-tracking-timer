<Window x:Class="FocusTrackingTimer.App.ProgramManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="프로그램 추가"
        Width="760"
        Height="640"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource ThemeBaseBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22"
                   FontWeight="SemiBold"
                   Text="{Binding TitleText}" />

        <TextBlock Grid.Row="1"
                   Margin="0,16,0,10"
                   Foreground="{StaticResource ThemeSecondaryTextBrush}"
                   Text="현재 실행 중인 프로그램만 표시되며, 작업 트레이의 프로그램은 감지되지 않습니다." />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding RunningProcesses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8"
                                Padding="12"
                                Background="{StaticResource ThemeBaseBackgroundBrush}"
                                BorderBrush="{StaticResource ThemeSecondaryBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ThemeSecondaryTextBrush}" Text="{Binding ProcessName}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Padding="14,7"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="FocusDetectedButton_Click"
                                        Content="보기" />
                                <Button Grid.Column="2"
                                        Padding="14,7"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="AddDetectedButton_Click"
                                        Content="추가"
                                        Foreground="{StaticResource ThemeActiveTextBrush}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
