<Window x:Class="FocusTrackingTimer.App.NameEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="이름 수정"
        Width="360"
        Height="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource ThemeBaseBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="16"
                   FontWeight="SemiBold"
                   Text="{Binding TitleText}" />

        <Grid Grid.Row="1" Margin="0,16,0,0" VerticalAlignment="Top">
            <TextBox Padding="10,8"
                     BorderBrush="{StaticResource ThemeSecondaryBorderBrush}"
                     BorderThickness="1"
                     Text="{Binding NameValue, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Margin="12,9,0,0"
                       Foreground="{StaticResource ThemeHintTextBrush}"
                       IsHitTestVisible="False"
                       Text="{Binding PlaceholderText}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding NameValue}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="78"
                    Height="34"
                    Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="CancelButton_Click"
                    Content="취소" />
            <Button Width="78"
                    Height="34"
                    Style="{StaticResource PrimaryButton}"
                    Click="SaveButton_Click"
                    Content="저장"
                    Foreground="{StaticResource ThemeActiveTextBrush}" />
        </StackPanel>
    </Grid>
</Window>
