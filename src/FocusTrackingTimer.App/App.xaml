<Application x:Class="FocusTrackingTimer.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/ThemeColors.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="Panel" TargetType="Border">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderBrush" Value="{StaticResource ThemeSecondaryBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{StaticResource ThemeSurfaceBrush}" />
            </Style>

            <Style x:Key="Divider" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ThemeSecondaryBorderBrush}" />
            </Style>

            <Style x:Key="FilterComboBox" TargetType="ComboBox">
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="BorderBrush" Value="{StaticResource ThemeSecondaryBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{StaticResource ThemePrimaryTextBrush}" />
            </Style>

            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource ThemeBaseBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ThemeSecondaryBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{StaticResource ThemePrimaryTextBrush}" />
            </Style>

            <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                <Setter Property="Background" Value="{StaticResource ThemeFocusBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ThemeFocusBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ThemeActiveTextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="MenuTabButton" TargetType="Button">
                <Setter Property="Padding" Value="18,7" />
                <Setter Property="BorderBrush" Value="{StaticResource ThemeTransparentBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource ThemeSecondaryTextBrush}" />
                <Setter Property="Background" Value="{StaticResource ThemeTransparentBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="TabChrome"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TagBadge" TargetType="Border">
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="Background" Value="{StaticResource ThemeSelectionBrush}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <Style x:Key="HoverActionButton" TargetType="Button">
                <Setter Property="Visibility" Value="Collapsed" />
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Margin" Value="6,0,0,0" />
                <Setter Property="Background" Value="{StaticResource ThemeTransparentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ThemeSecondaryBorderBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource ThemeSecondaryTextBrush}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
