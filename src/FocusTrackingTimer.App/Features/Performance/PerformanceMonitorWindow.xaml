<Window x:Class="FocusTrackingTimer.App.Features.Performance.PerformanceMonitorWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Performance Monitor"
        Icon="/Assets/app-icon.ico"
        Width="980"
        Height="1040"
        MinWidth="920"
        MinHeight="980"
        Background="#F7F7F4"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Text="Debug Performance Metrics" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#5B5B5B"
                               Text="Realtime values stay in memory. Trend charts read 1-minute aggregate log files." />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="#5B5B5B"
                           Text="{Binding RealtimeUpdatedAtText}" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Panel}" Padding="18">
            <TabControl Background="Transparent"
                        BorderThickness="0">
                <TabItem Header="Realtime">
                    <ScrollViewer Padding="0,14,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RealtimeRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Foreground="#3F3F3F"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Label}" />
                                        <TextBlock Grid.Column="1"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Value}" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,4,0,0"
                                                   Foreground="#6A6A6A"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Trend">
                    <Grid Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Margin="0,0,10,0"
                                      Height="34"
                                      Padding="8,4"
                                      Style="{StaticResource FilterComboBox}"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{Binding TrendMetricOptions}"
                                      SelectedItem="{Binding SelectedTrendMetricOption, Mode=TwoWay}"
                                      SelectionChanged="TrendSelector_SelectionChanged" />
                            <ComboBox Grid.Column="1"
                                      Margin="0,0,10,0"
                                      Height="34"
                                      Padding="8,4"
                                      Style="{StaticResource FilterComboBox}"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{Binding TrendRangeOptions}"
                                      SelectedItem="{Binding SelectedTrendRangeOption, Mode=TwoWay}"
                                      SelectionChanged="TrendSelector_SelectionChanged" />
                            <TextBlock Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="#5B5B5B"
                                       Text="{Binding TrendWindowText}" />
                        </Grid>

                        <TextBlock Grid.Row="2"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#5B5B5B"
                                   Text="{Binding TrendEmptyText}"
                                   Visibility="{Binding TrendEmptyVisibility}" />

                        <Grid Grid.Row="2" Visibility="{Binding TrendChartVisibility}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding TrendSummaryText}" />
                                <TextBlock Grid.Column="1"
                                           Foreground="#5B5B5B"
                                           Text="{Binding TrendLatestText}" />
                            </Grid>

                            <Border Grid.Row="2"
                                    Background="#FAFAF7"
                                    BorderBrush="#E1E1DA"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding TrendMaxText}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TrendMinText}" />
                                    </Grid>

                                    <Viewbox Grid.Row="2" Stretch="Fill">
                                        <Grid Width="760" Height="240">
                                            <Line X1="0" Y1="20" X2="760" Y2="20" Stroke="#ECECE4" StrokeThickness="1" />
                                            <Line X1="0" Y1="120" X2="760" Y2="120" Stroke="#ECECE4" StrokeThickness="1" />
                                            <Line X1="0" Y1="220" X2="760" Y2="220" Stroke="#ECECE4" StrokeThickness="1" />
                                            <Polyline Points="{Binding TrendPoints}"
                                                      Stroke="#1F1F1F"
                                                      StrokeThickness="3"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      StrokeStartLineCap="Round" />
                                        </Grid>
                                    </Viewbox>

                                    <TextBlock Grid.Row="4"
                                               HorizontalAlignment="Right"
                                               Foreground="#5B5B5B"
                                               Text="{Binding TrendPointCountText}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
