<Window x:Class="FocusTrackingTimer.App.Features.Timer.RunningProjectSummaryPipWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Tracking Timer"
        Icon="/Assets/app-icon.ico"
        Width="262"
        Height="138"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        SizeToContent="Manual"
        Topmost="True"
        WindowStyle="None"
        WindowStartupLocation="Manual">
    <Border Padding="10,8"
            Background="{StaticResource ThemeSurfaceBrush}"
            BorderBrush="{StaticResource ThemeSecondaryBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Margin="4,2,10,0"
                           VerticalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ThemePrimaryTextBrush}"
                           Text="{Binding RunningProjectNameText}"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <ToggleButton Width="28"
                                  Height="28"
                                  Style="{StaticResource StaticActionIconToggleButton}"
                                  Checked="AlwaysOnTopToggleButton_Checked"
                                  Unchecked="AlwaysOnTopToggleButton_Unchecked"
                                  IsChecked="True">
                        <ToggleButton.ToolTip>
                            <ToolTip>
                                <ToolTip.Style>
                                    <Style TargetType="ToolTip"
                                           BasedOn="{StaticResource CommonToolTipStyle}">
                                        <Setter Property="Content" Value="항상 위에 유지" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PlacementTarget.IsChecked, RelativeSource={RelativeSource Self}}"
                                                         Value="True">
                                                <Setter Property="Content" Value="항상 위 유지 해제" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToolTip.Style>
                            </ToolTip>
                        </ToggleButton.ToolTip>
                        <Grid>
                            <Image Width="20"
                                   Height="20"
                                   Source="/Assets/pin.png"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Stretch="Uniform">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <Image Width="20"
                                   Height="20"
                                   Source="/Assets/pin-filled.png"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Stretch="Uniform">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </ToggleButton>
                    <Button Width="28"
                            Height="28"
                            Margin="6,0,0,0"
                            Style="{StaticResource StaticActionIconButton}"
                            Click="RestoreMainWindowButton_Click">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource CommonToolTipStyle}"
                                     Content="메인 창으로 보기" />
                        </Button.ToolTip>
                        <Image Width="20"
                               Height="20"
                               Source="/Assets/pip.png"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               Stretch="Uniform" />
                    </Button>
                    <Button Width="28"
                            Height="28"
                            Margin="6,0,0,0"
                            Style="{StaticResource StaticActionIconButton}"
                            Click="CloseApplicationButton_Click"
                            Content="X"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource ThemeSecondaryTextBrush}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource CommonToolTipStyle}"
                                     Content="프로그램 닫기" />
                        </Button.ToolTip>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemePrimaryTextBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Text="{Binding RunningProjectWallClockText}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemeFocusBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Text="{Binding RunningProjectFocusText}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="0,0,2,4"
                            VerticalAlignment="Top">
                    <Grid>
                        <Button Width="82"
                                Height="34"
                                HorizontalAlignment="Center"
                                Background="{Binding TimerActionButtonBackground}"
                                Click="TimerActionButton_Click"
                                Content="{Binding TimerActionButtonText}"
                                Foreground="{Binding TimerActionButtonForeground}"
                                FontWeight="SemiBold"
                                IsEnabled="{Binding IsTimerActionEnabled}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TextPrimaryActionButton}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTimerActionOutlined}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Width="82"
                                Height="34"
                                HorizontalAlignment="Center"
                                Click="TimerActionButton_Click"
                                Content="{Binding TimerActionButtonText}"
                                FontWeight="SemiBold"
                                IsEnabled="{Binding IsTimerActionEnabled}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TextOutlineActionButton}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTimerActionOutlined}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <Button Margin="0,6,0,0"
                            Width="82"
                            Height="34"
                            HorizontalAlignment="Center"
                            Style="{StaticResource TextOutlineActionButton}"
                            Click="StopTimerButton_Click"
                            Content="중지"
                            IsEnabled="{Binding IsTimerStopEnabled}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
