{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "FocusTrackingTimer.sln"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "FocusTrackingTimer.sln"
      ],
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run-app",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/FocusTrackingTimer.App/FocusTrackingTimer.App.csproj"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
